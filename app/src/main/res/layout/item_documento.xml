<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card_surface"
    app:strokeColor="@color/divider"
    app:strokeWidth="0.5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/textNroDocumento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="SOL-2026-9081"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="@color/md_on_surface"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textTipoAdministrado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Carta Solicitud ┬À Juan P├®rez Corp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/md_on_surface_variant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textNroDocumento" />

        <TextView
            android:id="@+id/textExpediente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Exp: EXP-2026-001"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/md_outline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textTipoAdministrado" />

        <TextView
            android:id="@+id/textFechaFolios"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="2026-07-08 10:00  |  Folios: 5"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/md_outline"
            app:layout_constraintEnd_toStartOf="@id/imageSyncStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textExpediente" />

        <ImageView
            android:id="@+id/imageSyncStatus"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="Sync Status"
            android:src="@android:drawable/stat_sys_upload_done"
            app:layout_constraintBottom_toBottomOf="@id/textFechaFolios"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/textFechaFolios"
            app:tint="#4CAF50" />

        <TextView
            android:id="@+id/textSyncStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="Sincronizado"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="#4CAF50"
            app:layout_constraintBottom_toBottomOf="@id/imageSyncStatus"
            app:layout_constraintEnd_toStartOf="@id/imageSyncStatus"
            app:layout_constraintTop_toTopOf="@id/imageSyncStatus" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
